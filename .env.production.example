# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Database Configuration (PythonAnywhere)
# Format: postgresql://username:password@hostname:port/databasename
DATABASE_URL=postgresql://Azad:YOUR_PASSWORD@Azad-4977.postgres.pythonanywhere-services.com:14977/Azad$garage_db

# Security Settings
SESSION_COOKIE_SECURE=True
REMEMBER_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True

# Mail Server (SMTP) - Optional
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Application Settings
AI_SYSTEMS_ENABLED=True
ENABLE_AUTOMATED_BACKUPS=True
