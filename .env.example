# AzadAccounting-sys production environment example
# انسخ هذا الملف إلى .env على السيرفر ولا ترفع .env الحقيقي إلى GitHub.

# === Flask / Runtime ===
APP_ENV=production
DEBUG=false
FLASK_APP=app:create_app
HOST=127.0.0.1
PORT=5000
APP_VERSION=1.0.0

# أنشئ مفتاح قوي:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_long_random_secret

# === Database: PostgreSQL ===
# PythonAnywhere/PostgreSQL example:
# DATABASE_URL=postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_SSLMODE_REQUIRE=false

# PythonAnywhere/shared hosting: keep the pool modest.
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_TIMEOUT=30

# === Security ===
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=true
WTF_CSRF_SSL_STRICT=true
PASSWORD_HASH_METHOD=scrypt
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15
ENABLE_TIMING_ATTACK_PROTECTION=true
ENABLE_RACE_CONDITION_PROTECTION=true

# ضع رابط موقعك الحقيقي فقط، لا تستخدم * في الإنتاج.
CORS_ORIGINS=https://yourusername.pythonanywhere.com
SOCKETIO_CORS_ORIGINS=https://yourusername.pythonanywhere.com

# === Default seeded users: change before production use ===
OWNER_USERNAME=owner
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_me_owner_strong_password

DEVELOPER_USERNAME=developer
DEVELOPER_EMAIL=developer@example.com
DEVELOPER_PASSWORD=change_me_developer_strong_password

SUPER_ADMIN_USERNAME=azad
SUPER_ADMIN_EMAIL=rafideen.ahmadghannam@gmail.com
SUPER_ADMIN_PASSWORD=change_me_super_admin_strong_password

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_strong_password

MANAGER_USERNAME=manager
MANAGER_EMAIL=manager@example.com
MANAGER_PASSWORD=change_me_manager_strong_password

STAFF_USERNAME=staff
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=change_me_staff_strong_password

MECHANIC_USERNAME=mechanic
MECHANIC_EMAIL=mechanic@example.com
MECHANIC_PASSWORD=change_me_mechanic_strong_password

REGISTERED_CUSTOMER_USERNAME=customer
REGISTERED_CUSTOMER_EMAIL=customer@example.com
REGISTERED_CUSTOMER_PASSWORD=change_me_customer_strong_password

# === Cache / Rate limit ===
# On PythonAnywhere you may keep memory:// if Redis is not available.
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://
CACHE_TYPE=flask_caching.backends.simplecache.SimpleCache
CACHE_DEFAULT_TIMEOUT=1800

# === Mail ===
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER="AzadAccounting <noreply@example.com>"

# === Optional integrations ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
ONLINE_GATEWAY_DEFAULT=blooprint
BLOOPRINT_WEBHOOK_SECRET=

# === AI providers ===
# ابدأ بتعطيل AI في الاستضافة حتى تثبت الأداء، ثم فعّله عند الحاجة.
AI_SYSTEMS_ENABLED=false
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Backups ===
# على PythonAnywhere يفضّل ضبط النسخ الاحتياطي يدويًا أولًا.
ENABLE_AUTOMATED_BACKUPS=false
BACKUP_KEEP_LAST=5
BACKUP_DIR=./instance/backups

# === Business defaults ===
DEFAULT_CURRENCY=ILS
ITEMS_PER_PAGE=100
MAX_ITEMS_PER_PAGE=300
